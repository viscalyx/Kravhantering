  "ignoreRegExpList": [],
  "overrides": [
    {
      "filename": "**/package.json",
      "enabled": false
    },
    {
      "filename": "tests/guide/generate-guide.spec.ts",
      "words": [
        "annot",
        "domcontentloaded",
        "framenavigated",
        "requestfailed",
        "sugg"
      ]
    }
  ],
  "useGitignore": true,
  "enableFiletypes": [
    "markdown",
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "json",
    "jsonc",
    "yaml",
    "yml",
    "text",
    "plaintext"
  ],
  "caseSensitive": false,
  "allowCompoundWords": false,
  "suggestionsTimeout": 400
}
