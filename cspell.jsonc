    {
      "filename": "tests/guide/generate-guide.spec.ts",
      "words": ["annot", "sugg"]
    }
  ],
  "useGitignore": true,
  "enableFiletypes": [
    "markdown",
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "json",
    "jsonc",
    "yaml",
    "yml",
    "text",
    "plaintext"
  ],
  "caseSensitive": false,
  "allowCompoundWords": false,
  "suggestionsTimeout": 400
