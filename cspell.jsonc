  "flagWords": [],
  "ignorePaths": [
    "node_modules",
    ".next",
    "coverage",
    "test-results",
    "playwright-report*",
    "out/**",
    "dist/**",
    "build/**",
    "bundled/**",
    ".git/**",
    "*.min.js",
    "*.min.css",
    "package-lock.json",
    "worker-configuration.d.ts",
    "*.db",
    "*.png",
    "*.jpg",
    "*.pdf",
    "yarn.lock",
    "pnpm-lock.yaml",
    "tsconfig.tsbuildinfo",
    "coderabbit-ai-agent-prompts.md",
    ".cspell.json",
    ".cspell.jsonc"
  ],
  "ignoreRegExpList": [],
  "overrides": [
    {
      "filename": "**/package.json",
      "enabled": false
    },
    {
      "filename": "tests/guide/generate-guide.spec.ts",
      "words": [
        "annot",
        "domcontentloaded",
        "framenavigated",
        "requestfailed",
        "sugg"
      ]
    }
  ],
  "useGitignore": true,
  "enableFiletypes": [
    "markdown",
    "typescript",
    "typescriptreact",
    "javascript",
    "javascriptreact",
    "json",
    "jsonc",
    "yaml",
    "yml",
    "text",
    "plaintext"
  ],
  "caseSensitive": false,
  "allowCompoundWords": false,
  "suggestionsTimeout": 400
}
