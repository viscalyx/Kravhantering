# Devcontainer SQL Server settings
# Copy this file to .devcontainer/.env before rebuilding the devcontainer.
# The same file is used by both the default and elevated devcontainer profiles.
# The app/admin scripts derive SQL Server URLs from the DB_* values below.
# Uncomment DATABASE_URL / DATABASE_READONLY_URL only if you need an explicit
# override. Those full URLs are optional and override the individual DB_* values
# below.

ACCEPT_EULA=Y
MSSQL_PID=Developer
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
SQLSERVER_HOST_PORT=1433

DB_HOST=db
DB_PORT=1433
DB_NAME=kravhantering
DB_READONLY_USER=readonly
DB_READONLY_PASSWORD=BrowseOnly!Passw0rd7
DATABASE_READONLY_PASSWORD_ENV=DB_READONLY_PASSWORD
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Optional explicit overrides for the derived DB_* connection settings above:
# DATABASE_URL=mssql://sa:YourStrong!Passw0rd@db:1433/kravhantering?encrypt=true&trustServerCertificate=true
# DATABASE_READONLY_URL=mssql://readonly:BrowseOnly!Passw0rd7@db:1433/kravhantering?encrypt=true&trustServerCertificate=true

# Local OIDC IdP (Keycloak) — consumed by the `idp` service in the
# devcontainer compose files. These values only protect the Keycloak
# admin console at http://localhost:8080 in your local devcontainer
# — never reuse them anywhere else.
#
# App-level AUTH_*, NEXT_PUBLIC_SITE_URL, ANALYTICS_HASH_SECRET, etc. are
# NOT mirrored here. Next.js inside the devcontainer loads them from
# /workspace/.env.development (committed) and /workspace/.env.development.local
# (per-developer secrets, e.g. OPENROUTER_API_KEY) via the bind-mounted
# workspace. See /workspace/.env.example for the full reference.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HOST_PORT=8080
