{
  "editor.defaultFormatter": "biomejs.biome",
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "[tsv]": {
    // TSV files (e.g. .github/zap/rules.*.tsv) require literal tab
    // characters between fields. Force tabs and skip trim-on-save so
    // VS Code's global indent settings do not corrupt the columns.
    "editor.insertSpaces": false,
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "files.trimTrailingWhitespace": false
  },
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,

  // Code Spell Checker Configuration
  "cSpell.enabled": true,
  "cSpell.enabledFileTypes": {
    "markdown": true,
    "typescript": true,
    "typescriptreact": true,
    "javascript": true,
    "javascriptreact": true,
    "json": true,
    "jsonc": true,
    "yaml": true,
    "yml": true
  },
  "cSpell.diagnosticLevel": "Warning",
  "cSpell.checkLimit": 500,

  // Editor enhancements from devcontainer.json for non-container use
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.fixAll.markdownlint": "explicit",
    "source.organizeImports.biome": "explicit",
    "source.organizeImports": "never"
  },
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.rulers": [80, 120],
  "editor.wordWrap": "on",
  "editor.minimap.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,

  // File handling
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/.open-next": true,
    "**/.wrangler": true,
    "**/.git": true,
    "**/.DS_Store": true,
    "**/tsconfig.tsbuildinfo": true
  },

  // JavaScript and TypeScript settings
  "js/ts.preferences.quoteStyle": "single",
  "js/ts.preferences.importModuleSpecifier": "relative",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.suggest.autoImports": true,
  "js/ts.preferences.includePackageJsonAutoImports": "auto",

  // TailwindCSS settings
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript"
  },
  "tailwindCSS.classFunctions": ["cn", "clsx", "classNames", "tw"],
  "tailwindCSS.experimental.configFile": "app/globals.css",
  "tailwindCSS.lint.suggestCanonicalClasses": "error",

  // Spell Checker extras
  "cSpell.language": "en,sv",
  "cSpell.words": [],

  // Git settings
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,

  // Terminal settings
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "/bin/zsh"
    }
  },

  // Emmet settings
  "emmet.includeLanguages": {
    "typescript": "html",
    "typescriptreact": "html"
  },

  // Explorer settings
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  "sqltools.connections": [
    {
      "connectionTimeout": 15,
      "mssqlOptions": {
        "appName": "SQLTools",
        "useUTC": true,
        "encrypt": true,
        "trustServerCertificate": true
      },
      "ssh": "Disabled",
      "previewLimit": 50,
      "server": "db",
      "port": 1433,
      "askForPassword": true,
      "driver": "MSSQL",
      "name": "Kravhantering",
      "database": "Kravhantering",
      "username": "readonly"
    }
  ]
}
