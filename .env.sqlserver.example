# Host-side SQL Server scaffold settings
# Copy this file to .env.sqlserver before running `npm run db:up` outside the
# devcontainer. This file is ignored by Git so local secrets or overrides stay
# out of the repository.

ACCEPT_EULA=Y
MSSQL_PID=Developer
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
SQLSERVER_HOST_PORT=1433

SQLSERVER_DATABASE_URL=mssql://sa:YourStrong!Passw0rd@127.0.0.1:1433/kravhantering?encrypt=true&trustServerCertificate=true
SQLSERVER_DATABASE_READONLY_URL=mssql://readonly:Readonly!Passw0rd@127.0.0.1:1433/kravhantering?encrypt=true&trustServerCertificate=true
DATABASE_READONLY_PASSWORD=Readonly!Passw0rd
DATABASE_READONLY_PASSWORD_ENV=DATABASE_READONLY_PASSWORD
DB_TRUST_SERVER_CERTIFICATE=true
