# Public demo values for the application container.
# These values are unsafe for exposed operation. Copy to
# `.env.app.local` only for local Compose or smoke-test runs.

NEXT_PUBLIC_SITE_URL=https://kravhantering.test

# Public build metadata. Later CI/container phases should set concrete values.
BUILD_COMMIT_SHA=unknown
BUILD_IMAGE_TAG=local-dev
BUILD_TIME=
BUILD_VERSION=0.1.0

DB_ENCRYPT=true
DB_HOST=sqlserver
DB_NAME=kravhantering
DB_PASSWORD=AppDbPassword1!NotForProduction
DB_PORT=1433
DB_TRUST_SERVER_CERTIFICATE=true
DB_USER=kravhantering_app

AUTH_OIDC_API_AUDIENCE=kravhantering-app
AUTH_OIDC_CLIENT_ID=kravhantering-app
AUTH_OIDC_CLIENT_SECRET=container-demo-app-secret-not-for-production
AUTH_OIDC_ISSUER_URL=https://kravhantering.test/auth/realms/kravhantering-test
AUTH_OIDC_POST_LOGOUT_REDIRECT_URI=https://kravhantering.test/
AUTH_OIDC_REDIRECT_URI=https://kravhantering.test/api/auth/callback
AUTH_OIDC_ROLES_CLAIM=roles
# Quoted for dotenv-linter; write-env-local.mjs removes these quotes for
# Podman --env-file because Podman preserves quote characters.
AUTH_OIDC_SCOPES="openid profile email"
AUTH_SESSION_COOKIE_NAME=kravhantering_session
AUTH_SESSION_COOKIE_PASSWORD=container-demo-session-key-not-for-production-32chars
AUTH_SESSION_TTL_SECONDS=28800
MCP_CLIENT_ID=kravhantering-mcp

# Server-side HSA lookup through the environment's integration platform.
HSA_PERSON_LOOKUP_TIMEOUT_MS=5000
HSA_PERSON_LOOKUP_URL=https://kong.example.internal/hsa/person-records/lookup

# Optional app-to-external-integrationsplattform auth. Leave blank for the
# internal same-stack Kong route.
HSA_PERSON_LOOKUP_CA_PATH=
HSA_PERSON_LOOKUP_CLIENT_CERT_PATH=
HSA_PERSON_LOOKUP_CLIENT_KEY_PATH=
HSA_PERSON_LOOKUP_OAUTH_AUDIENCE=
HSA_PERSON_LOOKUP_OAUTH_CLIENT_ID=
HSA_PERSON_LOOKUP_OAUTH_CLIENT_SECRET=
HSA_PERSON_LOOKUP_OAUTH_ISSUER_URL=
HSA_PERSON_LOOKUP_OAUTH_SCOPE=
HSA_PERSON_LOOKUP_OAUTH_TOKEN_URL=
HSA_PERSON_LOOKUP_TLS_SERVER_NAME=

# Optional AI features. Real keys must only be supplied at runtime.
NEXT_PUBLIC_DEFAULT_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MGMT_API_KEY=
