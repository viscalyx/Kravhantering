# Public demo values for the Keycloak container.
# These values are unsafe for exposed operation. Copy to
# `.env.keycloak.local` only for local Compose or smoke-test runs.

KC_HEALTH_ENABLED=true
KC_HOSTNAME=https://kravhantering.test/auth
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080
KC_PROXY_HEADERS=xforwarded
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin-not-for-production
