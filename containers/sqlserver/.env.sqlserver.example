# Public demo values for the SQL Server container.
# These values are unsafe for exposed operation. Copy to
# `.env.sqlserver.local` only for local Compose or smoke-test runs.

ACCEPT_EULA=Y
MSSQL_PID=Developer
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

# Future local Compose generation may bind this as 127.0.0.1:1433 to keep
# SQL Server reachable only from the host loopback interface.
SQLSERVER_HOST_PORT=1433
