# Azure VM Remote SSH development scaffold.
# Copy to .env.azure.development.

# Non-secret values

AZURE_DEV_VM_LOCATION=eastus2
# Required non-secret Azure scope settings. Each must have a value.
AZURE_DEV_VM_RESOURCE_GROUP=rg-krav-dev-personal

# Azure VM settings with code defaults. These can be left unchanged.
AZURE_DEV_VM_ALLOWED_SSH_CIDR=auto
AZURE_DEV_VM_AUTO_STOP_ENABLED=true
AZURE_DEV_VM_AUTO_STOP_TIME=2200
AZURE_DEV_VM_AUTO_STOP_TIME_ZONE=UTC
AZURE_DEV_VM_CONNECTIVITY_MODE=public-ssh
AZURE_DEV_VM_DATA_DISK_GIB=256
AZURE_DEV_VM_ENVIRONMENT_ID=personal
AZURE_DEV_VM_FALLBACK_SIZE=Standard_D8as_v5 # or Standard_D16as_v5 if changing below
AZURE_DEV_VM_NAME=krav-dev-vm
AZURE_DEV_VM_NAME_PREFIX=krav-dev
# Standard_D8s_v5 — 8 vCPU, 32 GiB RAM - ~$0.384/hour.
# Standard_D16s_v5 — 16 vCPU, 64 GiB RAM - ~$0.768/hour.
# https://learn.microsoft.com/en-us/azure/virtual-machines/sizes/general-purpose/dsv5-series?tabs=sizebasic
# Prices above is just a hint, refer to Azure for exact pricing for the chosen Azure region.
AZURE_DEV_VM_SIZE=Standard_D8s_v5
AZURE_DEV_VM_SSH_HOST_ALIAS=kravhantering-azure-dev

# Optional Git identity overrides. By default, setup copies the effective
# user.name and user.email from this workstation's Git configuration.
# AZURE_DEV_GIT_USER_NAME=
# AZURE_DEV_GIT_USER_EMAIL=

# Optional SSH commit-signing public-key override. By default, setup copies the
# public key selected by local SSH commit-signing configuration when enabled.
# Use a public-key path or an inline key:: value. Never use private-key content.
# AZURE_DEV_GIT_SSH_SIGNING_KEY=~/.ssh/id_ed25519.pub

# Optional non-secret Tailscale settings.
# AZURE_DEV_VM_CONNECTIVITY_MODE=tailscale
# AZURE_DEV_TAILSCALE_TAILNET=

# Secrets
# Keep these in session variables or .env.azure.development.local.

# Required Azure subscription secret.
# AZURE_DEV_VM_SUBSCRIPTION_ID=

# SSH private-key path. The shown value is the code default.
# AZURE_DEV_VM_SSH_PRIVATE_KEY_PATH=~/.ssh/kravhantering_azure_dev_ed25519

# Required support-service secrets for setup.
# KEYCLOAK_ADMIN_PASSWORD=
# MSSQL_SA_PASSWORD=

# Optional service-principal secrets. Set all three together.
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# Optional Tailscale secret.
# AZURE_DEV_TAILSCALE_AUTH_KEY=

# Optional Ubuntu Pro token. When set, setup attaches the VM to Ubuntu Pro.
# AZURE_DEV_UBUNTU_PRO_TOKEN=
