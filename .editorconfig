# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{json,jsonc}]
indent_size = 2

[*.{ps1,psm1,psd1}]
indent_size = 4

[Makefile]
indent_style = tab

# TSV files are tab-delimited by definition. ZAP rules files
# (.github/zap/rules.*.tsv) and any other .tsv we ship rely on real
# tab characters between columns, so editors must not auto-convert
# them to spaces or trim trailing tabs.
[*.tsv]
indent_style = tab
trim_trailing_whitespace = false
